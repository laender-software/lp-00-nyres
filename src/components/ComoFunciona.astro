---
const etapas = [
  {
    numero: "01",
    titulo: "Escuta e compreensão profunda",
    descricao: "Espaço seguro para falar sobre suas dores, inseguranças e desafios sem julgamentos."
  },
  {
    numero: "02",
    titulo: "Identificação de padrões",
    descricao: "Reconhecimento dos comportamentos, crenças e emoções que sustentam o medo, a ansiedade e a dependência emocional."
  },
  {
    numero: "03",
    titulo: "Ferramentas práticas e vivenciais",
    descricao: "Exercícios que unem técnicas terapêuticas e práticas de expansão de consciência para transformar a forma como você se relaciona consigo e com os outros."
  },
  {
    numero: "04",
    titulo: "Autorresponsabilidade e maturidade emocional",
    descricao: "Desenvolvimento de recursos internos para lidar com conflitos, escolhas e relacionamentos com mais equilíbrio e autonomia."
  },
  {
    numero: "05",
    titulo: "Transformação e integração",
    descricao: "Aplicação das mudanças no seu dia a dia, criando relações mais saudáveis e uma vida alinhada à sua verdade."
  }
];
---

<section class="py-16 md:py-28 bg-cream" id="como-funciona">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16 reveal">
      <p class="text-teal-deep font-bold text-lg uppercase tracking-[0.2em] mb-3">Processo terapêutico</p>
      <h2 class="font-serif text-3xl md:text-4xl font-semibold text-brown">
        Como funciona meu trabalho
      </h2>
      <p class="text-brown-light text-lg mt-4 max-w-2xl mx-auto">
        Meu trabalho é estruturado, acolhedor e voltado para transformar padrões emocionais de forma profunda e consciente.
      </p>
    </div>

    <div class="space-y-8 max-w-3xl mx-auto">
      {etapas.map((etapa, i) => (
        <div class="reveal flex gap-6 items-start group" style={`transition-delay: ${i * 120}ms`}>
          <div class="flex-shrink-0 w-14 h-14 rounded-full bg-teal-deep/10 flex items-center justify-center group-hover:bg-teal-deep group-hover:scale-110 transition-all duration-300">
            <span class="font-serif text-xl font-bold text-teal-deep group-hover:text-white transition-colors duration-300">{etapa.numero}</span>
          </div>
          <div>
            <h3 class="font-serif text-xl font-semibold text-brown mb-2 group-hover:text-teal-deep transition-colors duration-300">{etapa.titulo}</h3>
            <p class="text-brown-light leading-relaxed">{etapa.descricao}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12 reveal">
      <a href="#contato" class="btn-glow border-2 border-teal-deep text-teal-deep px-8 py-4 rounded-full font-semibold hover:bg-teal-deep hover:text-white transition-all inline-block focus:outline-none focus:ring-2 focus:ring-teal-deep focus:ring-offset-2">
        Agendar Atendimento
      </a>
    </div>
  </div>
</section>
