---
---

<section class="min-h-[90vh] flex items-center bg-gradient-to-br from-cream via-warm to-cream pt-24 md:pt-0 overflow-hidden">
  <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
    <!-- Text -->
    <div class="reveal-left">
      <p class="text-teal font-medium text-sm uppercase tracking-[0.2em] mb-4">Autoconhecimento e Espiritualidade</p>
      <h1 class="font-serif text-4xl md:text-5xl lg:text-[3.5rem] font-semibold text-brown leading-tight mb-6">
        Alcance <span class="text-teal-deep">bem-estar</span>, maturidade e equilíbrio emocional
      </h1>
      <p class="text-brown-light text-lg md:text-xl leading-relaxed mb-8">
        Desperte sua maturidade emocional e reconecte-se com a essência que parecia esquecida. 
        Transforme medos e inseguranças em autoconfiança, clareza e equilíbrio interior.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#contato" class="btn-glow pulse-cta bg-teal-deep text-white px-8 py-4 rounded-full text-center font-semibold hover:bg-teal transition-all">
          Agende uma Consulta
        </a>
        <a href="#metodo" class="btn-glow border-2 border-teal-deep text-teal-deep px-8 py-4 rounded-full text-center font-semibold hover:bg-teal-deep hover:text-white transition-all">
          Conheça o Pathwork
        </a>
      </div>
    </div>

    <!-- Photo -->
    <div class="reveal-right flex justify-center">
      <div class="photo-zoom w-80 md:w-[26rem] rounded-2xl overflow-hidden shadow-2xl">
        <img
          src="/images/foto-profissional-1.jpg"
          alt="Nyres Edim — Terapeuta Pathwork"
          class="w-full h-full object-cover"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>
