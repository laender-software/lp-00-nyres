---
const eventos = [
  {
    data: "18 de abril de 2026",
    diaSemana: "Sábado",
    titulo: "A Coragem de Ser, Sem Provar Nada",
    tipo: "Workshop Vivencial",
    descricao: "Um encontro de um dia dedicado à investigação da relação que temos com o próprio valor — na natureza, a 35 km de BH.",
    link: "/workshop",
    vagas: "Vagas limitadas — máximo 12 participantes",
  },
];
---

<section class="py-16 md:py-28 bg-sand/40" id="eventos">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12 reveal">
      <p class="text-teal-deep font-bold text-lg uppercase tracking-[0.2em] mb-4">Agenda</p>
      <h2 class="font-serif text-3xl md:text-4xl font-semibold text-brown">Próximos eventos</h2>
    </div>

    <div class="space-y-6">
      {eventos.map(ev => (
        <div class="bg-white rounded-2xl shadow-sm overflow-hidden flex flex-col md:flex-row reveal">
          <!-- Data -->
          <div class="bg-teal-deep text-white flex flex-col items-center justify-center px-8 py-8 md:py-0 md:min-w-[160px] text-center flex-shrink-0">
            <p class="text-teal-soft text-xs font-bold uppercase tracking-widest mb-1">{ev.diaSemana}</p>
            <p class="font-serif text-lg font-semibold leading-snug">{ev.data}</p>
          </div>

          <!-- Conteúdo -->
          <div class="flex flex-col justify-center px-8 py-7 flex-1">
            <p class="text-teal-deep font-bold text-xs uppercase tracking-widest mb-1">{ev.tipo}</p>
            <h3 class="font-serif text-xl font-semibold text-brown mb-2">{ev.titulo}</h3>
            <p class="text-brown-light text-sm leading-relaxed mb-4">{ev.descricao}</p>
            <div class="flex flex-col sm:flex-row sm:items-center gap-3">
              <a
                href={ev.link}
                class="inline-block bg-teal-deep text-white px-6 py-3 rounded-full font-semibold text-sm hover:bg-teal transition-all text-center focus:outline-none focus:ring-2 focus:ring-teal-deep focus:ring-offset-2"
              >
                Ver detalhes
              </a>
              {ev.vagas && (
                <p class="text-brown-light/70 text-xs italic">{ev.vagas}</p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
